{
  "name": "www.gorilla.moe",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sv-sync": "svelte-kit sync",
    "dev": "vp dev",
    "build": "vp build",
    "postbuild": "svelte-sitemap",
    "preview": "vp preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vp test",
    "test:watch": "vp test watch",
    "lint": "vp fmt --check . && vp lint .",
    "format": "vp fmt .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@fontsource/jetbrains-mono": "5.2.8",
    "@fontsource/manrope": "5.2.8",
    "@fontsource/nanum-pen-script": "5.2.7",
    "@fontsource/permanent-marker": "5.2.7",
    "@fortawesome/fontawesome-free": "7.2.0",
    "@mistweaverco/mdsvex-shiki": "1.3.6",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.57.0",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@types/eslint": "9.6.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.17.0",
    "husky": "9.1.7",
    "install": "0.13.0",
    "jiti": "2.6.1",
    "mdsvex": "0.12.7",
    "rehype-autolink-headings": "7.1.0",
    "rehype-slug-custom-id": "2.0.0",
    "shiki": "4.0.2",
    "svelte": "5.55.2",
    "svelte-check": "4.4.6",
    "svelte-sitemap": "3.0.1",
    "typescript": "5.9.3",
    "unified": "11.0.5",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "trustedDependencies": [
    "esbuild"
  ],
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
